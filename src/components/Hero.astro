---
---
<section class="hero" id="hero">
  <div class="container hero-inner">

    <div class="hero-content animate-up">
      <p class="section-label">
        <span class="glow-dot"></span>
        Based in Australia · Grade 7
      </p>

      <h1 class="hero-name display">
        Kanav<br/>
        <span class="hero-name-last">Singhal</span>
      </h1>

      <div class="hero-roles">
        <span class="role-tag">School Captain</span>
        <span class="role-sep">·</span>
        <span class="role-tag">Debater</span>
        <span class="role-sep">·</span>
        <span class="role-tag">Gamer</span>
        <span class="role-sep">·</span>
        <span class="role-tag">Marvel Fan</span>
      </div>

      <p class="hero-bio animate-up delay-2">
        Thirteen years old and already leaving a mark. I lead, I argue (and I win),
        I learn obsessively, and I firmly believe Tony Stark was right about everything.
        This is my corner of the internet — a living record of who I am and who I'm becoming.
      </p>

      <div class="hero-cta animate-up delay-3">
        <a href="#about" class="btn btn-primary">Explore My World</a>
        <a href="#journal" class="btn btn-outline">Read My Journal</a>
      </div>
    </div>

    <div class="hero-visual animate-up delay-2" aria-hidden="true">
      <div class="arc-reactor">
        <div class="arc-outer">
          <div class="arc-ring arc-ring-1"></div>
          <div class="arc-ring arc-ring-2"></div>
          <div class="arc-ring arc-ring-3"></div>
          <div class="arc-core">
            <span class="arc-initials display">KS</span>
          </div>
        </div>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num display">01</span>
          <span class="hero-stat-label">School Captain</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num display">∞</span>
          <span class="hero-stat-label">Curiosity Level</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num display">3000</span>
          <span class="hero-stat-label">I love you, 3000</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Angled bottom edge -->
  <div class="hero-bottom-rule" aria-hidden="true"></div>
</section>

<style>
.hero {
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 64px;
  position: relative;
  z-index: 1;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  padding-top: 2rem;
  padding-bottom: 4rem;
}
.hero-name {
  font-size: clamp(5rem, 10vw, 9rem);
  color: var(--text-primary);
  line-height: 0.9;
  margin-bottom: 1.25rem;
}
.hero-name-last {
  color: var(--crimson);
  -webkit-text-stroke: 1px var(--crimson);
}
.hero-roles {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}
.role-tag {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--gold);
  letter-spacing: 0.08em;
}
.role-sep { color: var(--text-dim); }
.hero-bio {
  color: var(--text-muted);
  font-size: 1.05rem;
  max-width: 46ch;
  margin-bottom: 2rem;
  line-height: 1.8;
}
.hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; }

/* Arc Reactor visual */
.arc-reactor {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 2rem;
}
.arc-outer {
  position: relative;
  width: 220px; height: 220px;
  display: flex; align-items: center; justify-content: center;
}
.arc-ring {
  position: absolute;
  border-radius: 50%;
  border-style: solid;
  animation: spin linear infinite;
}
.arc-ring-1 {
  width: 220px; height: 220px;
  border-width: 1px;
  border-color: rgba(192,18,44,0.4) rgba(192,18,44,0.1) rgba(192,18,44,0.4) rgba(192,18,44,0.1);
  animation-duration: 18s;
}
.arc-ring-2 {
  width: 170px; height: 170px;
  border-width: 1px;
  border-color: rgba(232,184,75,0.5) rgba(232,184,75,0.1) rgba(232,184,75,0.5) rgba(232,184,75,0.1);
  animation-duration: 11s;
  animation-direction: reverse;
}
.arc-ring-3 {
  width: 124px; height: 124px;
  border-width: 2px;
  border-color: var(--crimson) transparent var(--crimson) transparent;
  animation-duration: 6s;
}
.arc-core {
  width: 84px; height: 84px;
  border-radius: 50%;
  background: var(--surface);
  border: 2px solid var(--gold);
  display: flex; align-items: center; justify-content: center;
  z-index: 1;
  box-shadow: 0 0 24px rgba(232,184,75,0.15), inset 0 0 16px rgba(232,184,75,0.08);
}
.arc-initials {
  font-size: 2rem;
  color: var(--gold);
  letter-spacing: 0.05em;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.hero-stats {
  display: flex;
  justify-content: center;
  gap: 2rem;
}
.hero-stat {
  text-align: center;
}
.hero-stat-num {
  display: block;
  font-size: 2rem;
  color: var(--gold);
}
.hero-stat-label {
  display: block;
  font-size: 0.7rem;
  font-family: var(--font-mono);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-top: 0.25rem;
}

.hero-bottom-rule {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, var(--crimson) 30%, var(--gold) 70%, transparent 100%);
  opacity: 0.3;
}

@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 2.5rem;
  }
  .hero-name { font-size: clamp(4rem, 18vw, 6rem); }
  .hero-roles { justify-content: center; }
  .hero-bio { margin-inline: auto; }
  .hero-cta { justify-content: center; }
  .hero-content { order: 2; }
  .hero-visual { order: 1; }
}
</style>
