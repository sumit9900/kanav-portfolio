---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Kanav Singhal — Student. Leader. Explorer.',
  description = 'Personal portfolio of Kanav Singhal — School Captain, debater, avid learner, Marvel enthusiast, and gamer.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Favicon (arc-reactor style placeholder) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style is:global>
    @import '/src/styles/global.css';
  </style>
</head>
<body>
  <div class="hex-bg" aria-hidden="true"></div>
  <slot />
</body>
</html>
